// prisma/schema.prisma — Database schema definition.
// Defines the data models for Percy. Each skill that needs persistent data
// adds its models here (prefixed with "Skill" + skill name).
// Run `pnpm db:migrate` to create/apply migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Core user model — every skill references this via userId.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Skill: Grocery List
  groceryCategories GroceryCategory[]
  groceryProducts   GroceryProduct[]
  groceryItems      GroceryItem[]

  // Shared: Household Members
  householdMembers HouseholdMember[]

  // Skill: TodoAtHome
  todoDomains  TodoDomain[]
  todoContexts TodoContext[]
  todoTasks    TodoTask[]
}

// ─── Skill: Grocery List ───────────────────────────────────────────

/// Catégorie de produit (optionnel — "Sans catégorie" par défaut)
model GroceryCategory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    GroceryItem[]
  products GroceryProduct[]

  @@unique([userId, name])
}

/// Produit récurrent — le "catalogue" personnel pour l'autocomplétion
model GroceryProduct {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  name       String
  categoryId String?
  category   GroceryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  usageCount Int              @default(1)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([userId, name])
}

/// Item sur la liste de courses active
model GroceryItem {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  name       String
  quantity   Int              @default(1)
  unit       String?
  categoryId String?
  category   GroceryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  checked    Boolean          @default(false)
  checkedAt  DateTime?
  sortOrder  Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

// ─── Shared: Household Members ──────────────────────────────────────
// Modèle partagé entre skills — utilisé pour l'assignation de tâches,
// les listes de courses, etc. Routes sous /api/household/members.

/// Membre du foyer (partagé entre tous les skills)
model HouseholdMember {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String   // "Moi", "Sophie", "Lucas"
  avatar    String?  // emoji ou URL d'avatar
  role      String?  // "parent", "enfant", "autre"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations vers les skills qui utilisent HouseholdMember
  todoTasks TodoTask[]

  @@unique([userId, name])
}

// ─── Skill: TodoAtHome ──────────────────────────────────────────────

/// Domaine — conteneur de haut niveau pour grouper les contextes.
/// Ex : "Maison", "Vie scolaire", "Santé", "Voiture"
model TodoDomain {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  name        String       // "Maison", "Vie scolaire", "Santé"
  icon        String       @default("🏠")
  description String?
  sortOrder   Int          @default(0)
  contexts    TodoContext[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, name])
}

/// Contexte — subdivision d'un domaine.
/// Ex : "Cuisine", "Salon", "Jardin" (pour le domaine Maison)
model TodoContext {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  domainId  String
  domain    TodoDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  name      String     // "Cuisine", "Salon", "Jardin"
  icon      String?    // emoji
  color     String     @default("#F59E0B")
  imageUrl  String?    // illustration optionnelle
  sortOrder Int        @default(0)
  isGlobal  Boolean    @default(false)
  tasks     TodoTask[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, domainId, name])
}

/// Tâche domestique assignable à un membre du foyer
model TodoTask {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  contextId   String
  context     TodoContext       @relation(fields: [contextId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String            @default("todo") // "todo", "in_progress", "done"
  priority    String            @default("normal") // "low", "normal", "high"
  color       String?
  dueDate     DateTime?
  assigneeId  String?
  assignee    HouseholdMember?  @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  sortOrder   Int               @default(0)
  completedAt DateTime?
  subtasks    TodoSubtask[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

/// Sous-tâche d'une tâche principale
model TodoSubtask {
  id        String   @id @default(cuid())
  taskId    String
  task      TodoTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
