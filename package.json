    "@vueuse/core": "^14.2.1",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.577.0",
    "nuxt": "^3.21.2",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.9.2",
    "shadcn-nuxt": "^2.4.3",
    "tailwind-merge": "^3.5.0",
