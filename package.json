    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.20.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.0",
    "prisma": "^7.8.0",
